generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
}

enum Size {
  SMALL
  MEDIUM
  LARGE
}

enum DeliveryMethod {
  PICKUP
  DELIVERY
}

enum OrderStatus {
  NEW
  PREPARING
  READY
  OUT_FOR_DELIVERY
  COMPLETE
  CANCELLED
}

enum PaymentMethod {
  APPLE_PAY_CARD
  VENMO
  CASH_APP
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AddOnType {
  TOPPING
  EXTRA_SYRUP
  ADULT_BOOSTER
}

enum IdVerificationStatus {
  NOT_REQUIRED
  REQUIRED
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  phone     String
  orders    Order[]
  addresses Address[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Address {
  id               String   @id @default(cuid())
  customerId       String?
  customer         Customer? @relation(fields: [customerId], references: [id])
  streetAddress    String
  normalizedStreet String
  houseNumber      String
  neighborhood     String
  orders           Order[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([normalizedStreet])
}

model Flavor {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  color       String
  priceSmall  Decimal     @db.Decimal(10, 2)
  priceMedium Decimal     @db.Decimal(10, 2)
  priceLarge  Decimal     @db.Decimal(10, 2)
  isAvailable Boolean     @default(true)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model AddOn {
  id                      String      @id @default(cuid())
  name                    String      @unique
  price                   Decimal     @db.Decimal(10, 2)
  type                    AddOnType
  isAvailable             Boolean     @default(true)
  requiresAgeVerification Boolean     @default(false)
  orderItems              OrderItem[] @relation("OrderItemAddOns")
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  @@index([type])
}

model Order {
  id                   String               @id @default(cuid())
  customerId           String?
  customer             Customer?            @relation(fields: [customerId], references: [id])
  addressId            String?
  address              Address?             @relation(fields: [addressId], references: [id])
  customerName         String
  phone                String
  streetAddress        String
  houseNumber          String
  neighborhood         String
  deliveryMethod       DeliveryMethod
  status               OrderStatus          @default(NEW)
  subtotal             Decimal              @db.Decimal(10, 2)
  tax                  Decimal              @db.Decimal(10, 2)
  total                Decimal              @db.Decimal(10, 2)
  paymentMethod        PaymentMethod
  paymentStatus        PaymentStatus        @default(PENDING)
  notes                String?
  containsAdultBooster Boolean              @default(false)
  ageConfirmed         Boolean              @default(false)
  idVerificationStatus IdVerificationStatus @default(NOT_REQUIRED)
  adultAdminApproved   Boolean              @default(false)
  stripeSessionId      String?
  items                OrderItem[]
  payment              Payment?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id       String  @id @default(cuid())
  orderId  String
  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  flavorId String
  flavor   Flavor  @relation(fields: [flavorId], references: [id])
  size     Size
  quantity Int     @default(1)
  unitPrice Decimal @db.Decimal(10, 2)
  addOns   AddOn[] @relation("OrderItemAddOns")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(10, 2)
  stripeSessionId String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
